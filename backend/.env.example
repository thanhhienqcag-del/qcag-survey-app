# --- Database (Neon PostgreSQL) --------------------------------------------
# Get from console.neon.tech -> Project -> Connection String
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Image hosting (GCS) ----------------------------------------------------
# Bucket dùng cho ảnh KS Mobile (hiện trạng, MQ, nghiệm thu)
# Bucket phải bật "allUsers" có quyền roles/storage.objectViewer
KS_GCS_BUCKET=your-ks-bucket-name

# --- App --------------------------------------------------------------------
NODE_ENV=development
PORT=3101

# --- CORS -------------------------------------------------------------------
# Comma-separated allowlist origins, or * to allow all
ALLOWED_ORIGINS=https://your-survey-app.vercel.app,https://your-quote-app.vercel.app
