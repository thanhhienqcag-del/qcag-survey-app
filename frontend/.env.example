# Preferred backend URL for KS API (optional).
# Leave empty to use same-origin proxy /api/ks/*.
BACKEND_URL=

# Alternative key (same meaning as BACKEND_URL).
KS_BACKEND_URL=

# Extra fallback backend URL (optional).
KS_BACKEND_FALLBACK_URL=

# Comma-separated backend candidates (optional).
# Example:
# KS_BACKEND_CANDIDATES=https://backend-a.example.com,https://backend-b.example.com
KS_BACKEND_CANDIDATES=

