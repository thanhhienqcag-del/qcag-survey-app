{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/ks/push/(.*)", "destination": "/api/ks/push/$1" },
    { "source": "/api/ks/(.*)", "destination": "/api/ks-proxy?path=$1" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
