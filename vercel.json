{
  "version": 2,
  "rewrites": [
    { "source": "/api/ks/push/(.*)", "destination": "/frontend/api/ks/push/$1" },
    { "source": "/api/ks/(.*)", "destination": "/frontend/api/ks-proxy?path=$1" },
    { "source": "/api/(.*)", "destination": "/frontend/api/$1" },
    { "source": "/app/(.*)", "destination": "/frontend/app/$1" },
    { "source": "/sw.js", "destination": "/frontend/sw.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
